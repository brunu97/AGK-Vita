+#ifdef AGK_VITA
+	/* On Vita there is no separate window/context object — vitaGL owns the
+	 * SceGxm context internally. The renderer just records the size. */
+	static int g_iVitaSurfaceW = 960;
+	static int g_iVitaSurfaceH = 544;
+
+	void SetRendererPointers( void *ptr ) { (void)ptr; }
+	/* The Vita display is always 960x544 — return it fixed so the engine's
+	 * surface size can never end up 0x0. */
+	int GetSurfaceWidth()                 { (void)g_iVitaSurfaceW; return 960; }
+	int GetSurfaceHeight()                { (void)g_iVitaSurfaceH; return 544; }
+
+	int GLESCreateRendererWindow( void *ptr, int deviceWidth, int deviceHeight )
+	{
+		(void)ptr;
+		if ( deviceWidth  > 0 ) g_iVitaSurfaceW = deviceWidth;
+		if ( deviceHeight > 0 ) g_iVitaSurfaceH = deviceHeight;
+		return 1;
+	}
+	void GLESSetRendererPointers( void *ptr, int deviceWidth, int deviceHeight )
+	{
+		(void)ptr;
+		if ( deviceWidth  > 0 ) g_iVitaSurfaceW = deviceWidth;
+		if ( deviceHeight > 0 ) g_iVitaSurfaceH = deviceHeight;
+	}
+#endif
